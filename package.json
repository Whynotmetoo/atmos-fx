{
  "name": "atmos-fx",
  "version": "0.1.3",
  "description": "DOM-aware atmosphere effects for creative interfaces.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Whynotmetoo/atmos-fx.git"
  },
  "homepage": "https://atmosfx.carsonye.com",
  "keywords": [
    "atmosphere",
    "canvas",
    "creative-coding",
    "dom-effects",
    "weather"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.js"
    },
    "./styles.css": "./dist/atmos-fx.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:bundle && npm run build:types && npm run build:styles",
    "build:bundle": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "build:styles": "mkdir -p dist/styles && cp src/styles/atmos-fx.css dist/atmos-fx.css && cp src/styles/atmos-fx.css dist/styles/atmos-fx.css",
    "build:docs": "vite build --config vite.config.docs.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0 || >=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
